{
  // - Linux:   all tasks work natively
  // - macOS:   all tasks work natively; macOS-specific targets only make sense here
  // - Windows: requires MSYS2 or WSL; run tasks from a WSL/MSYS2 terminal instead
  "version": "2.0.0",
  "tasks": [
    {
      "label": "autogen + configure",
      "type": "shell",
      "command": "./autogen.sh && ./configure",
      "group": "build",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },

