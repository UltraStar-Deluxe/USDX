; config.inp
; Configuration File for projectM
[ProjectM]
; Size of internal rendering texture
Texture Size = 128

; Width of PerPixel Equation mesh
Mesh X  = 32

; Height of PerPixel Equation mesh            	
Mesh Y  = 24

; in seconds
Smooth Transition Duration = 5
Preset Duration = 60
Easter Egg Parameter = 1

; Lower to make hard cuts more frequent
Hard Cut Sensitivity = 10

; Custom Shape Aspect Correction
Aspect Correction = true

Preset Path = visuals/projectM/presets
