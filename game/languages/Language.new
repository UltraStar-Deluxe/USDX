;TODO: SEC_010 = Save
;TODO: R = Reload song
;TODO: S = Save song with absolute timings (#RELATIVE:No)
;TODO: SHIFT_S = Save song with relative timings (#RELATIVE:Yes)
;-------------------------------------------------------;
;TODO: SEC_020 = Basic Navigation
;TODO: UPDOWN = Go to previous/next line
;TODO: LEFTRIGHT = Go to previous/next note
;-------------------------------------------------------;
;TODO: SEC_030 = Playback
;TODO: PAGEUPDOWN = Adjust song volume
;TODO: SPACE = Play Audio for current note
;TODO: SHIFT_SPACE = Play MIDI for current note
;TODO: CTRL_SHIFT_SPACE = Play Audio+MIDI for current note
;TODO: P = Play Audio+CLICKS for current line
;TODO: SHIFT_P = Play MIDI for current line
;TODO: CTRL_SHIFT_P = Play MIDI+Audio+CLICKS for current line
;TODO: ALT_P = Play Audio+CLICKS from current line onwards
;TODO: SHIFT_ALT_P = Play MIDI from current line onwards
;TODO: CTRL_SHIFT_ALT_P = Play MIDI+Audio+CLICKS from current line onwards
;TODO: V = Play VIDEO from current line onwards
;TODO: SHIFT_V = Play VIDEO+CLICKS from current line onwards
;-------------------------------------------------------;
;TODO: SEC_040 = Note Type
;TODO: G = Toggle golden note
;TODO: F = Toggle freestyle note
;-------------------------------------------------------;
;TODO: SEC_041 = Note Pitch
;TODO: SHIFT_UP = Increase current note by 1 semitone
;TODO: SHIFT_DOWN = Decrease current note by 1 semitone
;TODO: KPPLUS = Increase all notes by 1 semitone
;TODO: KPMINUS = Decrease all notes by 1 semitone
;TODO: SHIFT_KPPLUS = Increase all notes by 12 semitones (1 octave)
;TODO: SHIFT_KPMINUS = Decrease all notes by 12 semitones (1 octave)
;TODO: CTRL_ALT_PAGEUP = Increase all notes by 1 semitone
;TODO: CTRL_ALT_PAGEDOWN = Decrease all notes by 1 semitone
;TODO: CTRL_SHIFT_ALT_PAGEUP = Increase all notes by 12 semitones (1 octave)
;TODO: CTRL_SHIFT_ALT_PAGEDOWN = Decrease all notes by 12 semitones (1 octave)
;TODO: CTRL_PAGEUP = Increase all notes of current line by 1 semitone
;TODO: CTRL_PAGEDOWN = Decrease all notes of current line by 1 semitone
;TODO: CTRL_SHIFT_PAGEUP = Increase all notes of current line by 12 semitones (1 octave)
;TODO: CTRL_SHIFT_PAGEDOWN = Decrease all notes of current line by 12 semitones (1 octave)
;-------------------------------------------------------;
;TODO: SEC_042 = Voice Pitch Recording
;TODO: N = Set note pitch of current note to the last detected voice pitch.
;TODO: SHIFT_N = Record voice pitch for current line.
;TODO: ALT_N = Start voice pitch recording from current position.
;-------------------------------------------------------;
;TODO: SEC_043 = Note Position
;TODO: SHIFT_DELETE = Delete line
;TODO: CTRL_DELETE = Delete note
;TODO: CTRL_SLASH = Divide note into two
;TODO: SHIFT_LEFT = Move whole note left
;TODO: SHIFT_RIGHT = Move whole note right
;TODO: CTRL_LEFT = Move start of note left (lengthen note)
;TODO: CTRL_RIGHT = Move start of note right (shorten note)
;TODO: ALT_LEFT = Move end of note left (lengthen note)
;TODO: ALT_RIGHT = Move end of note right (shorten note)
;TODO: CTRL_ALT_SHIFT_LEFT = Move this note and all notes after it left
;TODO: CTRL_ALT_SHIFT_RIGHT = Move this note and all notes after it right
;-------------------------------------------------------;
;TODO: SEC_045 = Lyrics
;TODO: F4 = Toggle lyrics editor
;TODO: RETURN = Exit lyrics editor
;TODO: BACKSPACE = Delete character of selected note in lyrics editor
;TODO: PERIOD = Move current text to next note of current line
;TODO: T = Correct line breaks and timings
;TODO: C = Correct capitalization of first letter of each line
;TODO: SHIFT_C = Remove unnecessary spaces in current line
;TODO: SLASH = Insert a line break before current note
;TODO: SHIFT_SLASH = Remove the line break before current line
;-------------------------------------------------------;
;TODO: SEC_050 = Preview Tags
