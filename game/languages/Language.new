[ID_022]
;TODO: Title = Song
;TODO: Description = Lyrics appear one line at a time at the bottom/top with notes in the center
;-------------------------------------------------------;
;TODO: SUB_010 = Scoring
;TODO: ENT_011 = ♫ The maximum score on any song including bonus points is scaled to 10,000 points
;TODO: ENT_012 = ♫ If a note is sung accurately (depending on difficulty), it scores points
;TODO: ENT_013 = ♫ The longer this note is held throughout its duration, the more points are scored
;-------------------------------------------------------;
;TODO: SUB_020 = Line Bonus
;TODO: ENT_021 = ♫ A line bonus is awarded for every line where all notes are sung accurately
;-------------------------------------------------------;
;TODO: SUB_030 = Golden Notes
;TODO: ENT_031 = ♫ Golden notes score additional bonus points as they are usually harder to hit
;-------------------------------------------------------;
;TODO: SUB_040 = Freestyle Notes
;TODO: ENT_041 = ♫ Freestyle notes score no points and are generally only used for lyrics with no tune
;TODO: ENT_042 = ♫ No notes appear on-screen and the corresponding lyrics appear in italics
;-------------------------------------------------------;
