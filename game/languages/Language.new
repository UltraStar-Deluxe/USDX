;TODO: J = Jump to MedleyStart note
;TODO: SHIFT_J = Jump to MedleyEnd note
;TODO: ALT_J = Play medley section
;-------------------------------------------------------;
;TODO: SEC_070 = Duet Songs
;TODO: CTRL_SHIFT_D = Toggle P2 (second player) track
;TODO: CTRL_UP = Switch to P1 track
;TODO: CTRL_DOWN = Switch to P2 track
;TODO: CTRL_SHIFT_DOWN = Copy current line of 1st track into 2nd track
;TODO: CTRL_SHIFT_UP = Copy current line of 2nd track into 1st track
;TODO: CTRL_ALT_SHIFT_DOWN = Move current line of 1st track into 2nd track
;TODO: CTRL_ALT_SHIFT_UP = Move current line of 2nd track into 1st track
;-------------------------------------------------------;
;TODO: SEC_080 = Gap & VideoGap
;TODO: 0 = Increase GAP by 10 ms
;TODO: SHIFT_0 = Increase GAP by 1000 ms
;TODO: 9 = Decrease GAP by 10 ms
;TODO: SHIFT_9 = Decrease GAP by 1000 ms
