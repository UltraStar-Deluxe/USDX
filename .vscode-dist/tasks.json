{
  "version": "2.0.0",

  "tasks": [
    // -------------------------------------------------------
    // Setup (manual)
    // -------------------------------------------------------
    {
      "label": "[helper] autogen",
      "type": "shell",
      "command": "./autogen.sh"
    },
    {
      "label": "[helper] configure",
      "type": "shell",
      "command": "./configure ${input:configureArgs}"
    },
    {
      "label": "[any] 1. autogen & configure",
      "dependsOn": ["[helper] autogen", "[helper] configure"],
      "dependsOrder": "sequence",
    },

    // -------------------------------------------------------
    // Build
    // -------------------------------------------------------
    {
      "label": "[any] 2. make all",
      "type": "shell",
      "command": "make all",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    // -------------------------------------------------------
    // Variants
    // -------------------------------------------------------
    {
      "label": "[any] 2.a make debug",
      "type": "shell",
      "command": "make debug"
    },
    {
      "label": "[any] 2.b make release",
      "type": "shell",
      "command": "make release"
    },
    {
      "label": "[any] 2.c make rebuild",
      "type": "shell",
      "command": "make rebuild"
    },

    // -------------------------------------------------------
    // macOS extras
    // -------------------------------------------------------
    {
      "label": "[macos] make macos-app",
      "type": "shell",
      "command": "make macos-app",
      "osx": {
        "group": "build"
      }
    },
    {
      "label": "[macos] make macos-standalone-app",
      "type": "shell",
      "command": "make macos-standalone-app",
      "osx": {
        "group": "build"
      }
    },
    {
      "label": "[macos] make macos-dmg",
      "type": "shell",
      "command": "make macos-dmg",
      "osx": {
        "group": "build"
      }
    },

    // -------------------------------------------------------
    // Install
    // -------------------------------------------------------
    {
      "label": "[any] make install",
      "type": "shell",
      "command": "make install"
    },
    {
      "label": "[any] make uninstall",
      "type": "shell",
      "command": "make uninstall"
    },

    // -------------------------------------------------------
    // Clean
    // -------------------------------------------------------
    {
      "label": "[any] make clean",
      "type": "shell",
      "command": "make clean"
    },
    {
      "label": "[any] make distclean",
      "type": "shell",
      "command": "make distclean"
    },

    // -------------------------------------------------------
    // Run helpers
    // -------------------------------------------------------
    {
      "label": "[any] run",
      "type": "shell",
      "command": "./game/ultrastardx",
      "dependsOn": "build",
      "problemMatcher": []
    },
    {
      "label": "[any] run with songpath",
      "type": "shell",
      "command": "./game/ultrastardx -songpath ${input:songpath}",
      "dependsOn": "build",
      "problemMatcher": []
    },
    {
      "label": "[macos] run macos-standalone-app",
      "type": "shell",
      "command": "open build/macOS/ultrastardx.app",
      "osx": {},
      "problemMatcher": []
    }
  ],

  "inputs": [
    {
      "id": "configureArgs",
      "type": "promptString",
      "description": "Arguments for ./configure",
      "default": ""
    },
    {
      "id": "songpath",
      "type": "promptString",
      "description": "Path to songs folder",
      "default": "songs"
    }
  ]
}